# Rappi credentials — copy this file to .env and fill in your values.
# Run rappi_auth() from Claude to populate these automatically.
#
# Manual extraction: log into rappi.cl in Chrome, then read these cookies:
#   rappi.data  (Base64 JSON) → user_id
#   deviceid                  → device_id
#   rappi_refresh_token       → refresh_token
# Then exchange refresh_token at POST /api/rocket/refresh-token for access_token.

RAPPI_ACCESS_TOKEN=ft.gAAAAA...
RAPPI_REFRESH_TOKEN=ft.gAAAAA...
RAPPI_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RAPPI_USER_ID=12345678

